# ── AI Models ─────────────────────────────────────────────────
# Vision extraction (SCANNED_PDF, ảnh chụp): gemini-2.5-flash
GOOGLE_API_KEY_VISION=your-gemini-2.5-flash-api-key
GEMINI_VISION_MODEL=gemini-2.5-flash

# Text extraction (SOFT_PDF, OCR output): gemini-2.5-flash-lite
GOOGLE_API_KEY_TEXT=your-gemini-2.5-flash-lite-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite

# Fallback nếu không set riêng
GOOGLE_API_KEY=your-google-api-key-here

# ── OCR Configuration ─────────────────────────────────────────
# Options: paddleocr | easyocr | tesseract | auto
OCR_ENGINE=auto
OCR_LANGUAGE=vi+en
CONFIDENCE_THRESHOLD=0.65

# ── Processing ────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads
RESULTS_DIR=results
MAX_CONCURRENT_JOBS=3

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── Security ──────────────────────────────────────────────────
# Set this to your desired API key (plain text or SHA256 hex).
# Leave blank to disable authentication.
# Generate a key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
